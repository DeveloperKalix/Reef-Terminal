# Firebase Web App config — get from Firebase Console → Project Settings → Your apps → Web app
# These are PUBLIC values (safe in the browser bundle). Security comes from Firebase Security Rules.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=reef-media-trust-panel.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=reef-media-trust-panel
VITE_FIREBASE_STORAGE_BUCKET=reef-media-trust-panel.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
